# .env.example — Copy to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# Application
BASE_URL=https://staging.yourapp.com
API_BASE_URL=https://api.yourapp.com

# Test credentials (use dedicated test accounts, not real user accounts)
ADMIN_EMAIL=admin@testapp.com
ADMIN_PASS=Admin@Secure123!
VIEWER_EMAIL=viewer@testapp.com
VIEWER_PASS=Viewer@Secure123!

# API
API_TOKEN=your-api-bearer-token-here

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
