{
  "name": "qa-automation-portfolio",
  "version": "1.0.0",
  "description": "Production-grade QA Automation Portfolio — Playwright + Selenium, CI/CD, POM, Reporting",
  "scripts": {
    "test:playwright": "playwright test",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:ui": "playwright test --ui",
    "test:selenium": "node tests/selenium/runner.js",
    "test:all": "npm run test:playwright && npm run test:selenium",
    "report": "playwright show-report",
    "report:open": "open reports/index.html",
    "lint": "eslint tests/ pages/ utils/",
    "format": "prettier --write ."
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "git": "^0.1.5",
    "selenium-webdriver": "^4.18.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.44.0",
    "allure-playwright": "^3.0.0",
    "eslint": "^9.2.0",
    "prettier": "^3.2.5"
  },
  "keywords": [
    "playwright",
    "selenium",
    "automation",
    "qa",
    "testing",
    "ci-cd"
  ],
  "author": "QA Automation Engineer",
  "license": "MIT"
}
